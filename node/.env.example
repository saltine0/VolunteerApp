# Auth0 credentials (from your Auth0 application dashboard)
AUTH0_CLIENT_ID=your_client_id
AUTH0_CLIENT_SECRET=your_client_secret
AUTH0_DOMAIN=your-domain.us.auth0.com

# Must match your app's public URL (used for Auth0 callback)
BASE_URL=http://localhost:3000

# Random string used to sign the session cookie — change this!
SESSION_SECRET=change_this_to_a_long_random_string

# Server port
PORT=3000

# Data file paths (relative to the node/ directory)
DATA_FILE=data/data.json
EMAIL_CONFIG_FILE=data/email-config.json

# Secret used to secure the /api/run-reminders endpoint.
# Set this to any long random string and add it to your cron scheduler's
# Authorization header as: Bearer <value>
CRON_SECRET=change_this_to_a_long_random_string
